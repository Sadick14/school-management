# Application Settings

APP_NAME="DevSuite Edu"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Africa/Accra
APP_LOCALE=en
MAX_RECORD_PER_PAGE= 25
INSTITUTE_CATEGORY=school
CURRENCY_SYMBOL="GH₵"
HOUSE_LIST=""

# Its only for college. value will the the title of the year
DASHBOARD_STUDENT_COUNT_DEFAULT_ACADEMIC_YEAR=2026

# Website frontend Settings
MAX_RECORD_PER_PAGE_FRONT= 10
GA_TRACK_ID=


# DB Settings
# SQLite - the database file lives at database/database.sqlite.
# Leave DB_DATABASE unset so the path resolves automatically on any machine.

DB_CONNECTION=sqlite

# Log, Session, Job Queue Settings

BROADCAST_DRIVER=log
LOG_CHANNEL=stack
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# Storage Settings

FILESYSTEM_DRIVER=local

# Pusher Settings
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"


# Email Server Settings

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# website admin email address for receive contact email

MAIL_RECEIVER=contact@devsuiteedu.com
MAIL_NO_REPLY_ADDRESS=no-reply@devsuiteedu.com


# Deployment settings

DEVELOPER_MODE_ENABLED=false
